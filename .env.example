# Connection for tools/abap + tools/build.sh — copy to .env and fill in.
# .env is gitignored; never commit real credentials.

# ADT base URL of the ABAP system (host:port). http or https.
SAP_URL=http://your-host:50000

# SU01 user + a NON-initial password (log in once via GUI to clear "change on first logon").
SAP_USER=DEVELOPER
SAP_PASSWORD=change-me

# Client (optional; default 001).
SAP_CLIENT=001

# Target package for created objects (your Z/Y package).
SAP_PACKAGE=ZLOCAL

# Transport request — required for transportable packages; leave EMPTY for local ($TMP) packages.
SAP_TRANSPORT=

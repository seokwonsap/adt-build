#!/usr/bin/env python3
"""
abap — one smart command to build any ABAP object headless via raw ADT REST.

  abap <file>                  # auto-detect type + name from the source, build (+activate, +publish/run)
  abap <file> --run            # class: also run classrun
  abap <file> --group ZFG      # function module: target group
  abap --type fugr --name ZFG_DEMO          # no-source types (fugr)
  abap --type srvb --name ZX_O4 --srvd ZX   # service binding (+auto publish)
  abap probe                   # report the real host/client/package/transport — discover, don't assume

One CLI for 16 object types. Logic lives in the TYPES registry (data) + one engine.
Config from ../.env: SAP_URL, SAP_USER, SAP_PASSWORD, SAP_PACKAGE (SAP_CLIENT/SAP_TRANSPORT optional). See README.md.
Nothing system-specific is defaulted: sap-client is omitted unless set (server uses the logon default);
package & transport are validated (run `abap probe`), not guessed.
"""
import os, re, sys, base64, argparse, urllib.request, urllib.parse, http.cookiejar, ssl, html
# cross-platform: never crash on a Windows cp1252 console if output holds non-ASCII (e.g. SAP message text)
try: sys.stdout.reconfigure(encoding='utf-8', errors='replace'); sys.stderr.reconfigure(encoding='utf-8', errors='replace')
except Exception: pass

# ---- env ----
HERE = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
def load_env():
    p = os.path.join(HERE, '.env')
    if os.path.exists(p):
        for line in open(p):
            line = line.strip()
            if line and not line.startswith('#') and '=' in line:
                k, v = line.split('=', 1)
                v = v.strip()
                if len(v) >= 2 and v[0] in '"\'' and v[-1] == v[0]: v = v[1:-1]  # strip matching surrounding quotes
                os.environ.setdefault(k.strip(), v)
load_env()
NS = 'xmlns:adtcore="http://www.sap.com/adt/core"'
# all system-specifics come from .env (+ CLI flags) — nothing hardcoded. resolved in configure():
B_URL = USER = PW = TR = PKG = CLIENT = AUTH = None; VERBOSE = False
def configure(a=None):
    global B_URL, USER, PW, TR, PKG, CLIENT, AUTH, _ctx, VERBOSE
    g = os.environ.get
    VERBOSE = bool(a and getattr(a, 'verbose', False))
    B_URL  = (a and a.host) or g('SAP_URL') or sys.exit('set SAP_URL=http://host:port (.env or --host)')
    _ctx   = ssl._create_unverified_context() if (a and a.insecure) else ssl.create_default_context()
    USER   = (a and a.user) or g('SAP_USER') or sys.exit('set SAP_USER (.env or --user)')
    PW     = g('SAP_PASSWORD') or sys.exit('set SAP_PASSWORD (.env)')
    CLIENT = (a and a.client) or g('SAP_CLIENT')   # unset -> sap-client omitted (server uses logon default)
    PKG    = (a and a.package) or g('SAP_PACKAGE') or sys.exit('set SAP_PACKAGE (.env or --package)')
    TR     = (a and a.transport) or g('SAP_TRANSPORT', '')   # empty = omit corrNr (local/non-transportable pkg)
    AUTH   = 'Basic ' + base64.b64encode(f'{USER}:{PW}'.encode()).decode()

# ---- type registry (data, not code) ----
# coll: collection endpoint · atype: adtcore type for activation · media: create media type
# mode: src (text->source/main) | xml (object xml->object uri) | createonly (create+activate, no put)
# name_re: regex to pull the object name from the source · cre: create-payload builder
def _cre_blue(t):  # <blue:blueSource> create (tabl/stru/bdef)
    extra = ' xmlns:abapsource="http://www.sap.com/adt/abapsource" abapsource:fixPointArithmetic="false" abapsource:activeUnicodeCheck="false"' if t == 'TABL/DT' else ''
    return lambda n, **k: (f'<?xml version="1.0" encoding="UTF-8"?><blue:blueSource xmlns:blue="http://www.sap.com/wbobj/blue"{extra} {NS} '
                           f'adtcore:name="{n}" adtcore:type="{t}" adtcore:description="{n}"><adtcore:packageRef adtcore:name="{PKG}"/></blue:blueSource>')
def _cre(root, ns, atype, attrs=''):
    return lambda n, **k: (f'<?xml version="1.0" encoding="UTF-8"?><{root} {ns} {NS} adtcore:name="{n}" '
                           f'adtcore:type="{atype}" adtcore:description="{n}"{attrs}><adtcore:packageRef adtcore:name="{PKG}"/></{root}>')

def _cre_fm(n, **k):
    return (f'<?xml version="1.0" encoding="UTF-8"?><fmodule:abapFunctionModule xmlns:fmodule="http://www.sap.com/adt/functions/fmodules" {NS} '
            f'adtcore:name="{n}" adtcore:type="FUGR/FF" adtcore:description="{n}" fmodule:processingType="normal" fmodule:releaseState="notReleased"/>')
def _cre_srvb(n, srvd=None, **k):
    sdl = (srvd or '').lower()
    return (f'<?xml version="1.0" encoding="UTF-8"?><srvb:serviceBinding xmlns:srvb="http://www.sap.com/adt/ddic/ServiceBindings" {NS} '
            f'srvb:contract="C1" adtcore:name="{n}" adtcore:type="SRVB/SVB" adtcore:description="{n}"><adtcore:packageRef adtcore:name="{PKG}"/>'
            f'<srvb:services srvb:name="{n}"><srvb:content srvb:version="0001" srvb:releaseState="NOT_RELEASED">'
            f'<srvb:serviceDefinition adtcore:uri="/sap/bc/adt/ddic/srvd/sources/{sdl}" adtcore:type="SRVD/SRV" adtcore:name="{srvd}"/></srvb:content></srvb:services>'
            f'<srvb:binding srvb:type="ODATA" srvb:version="V4" srvb:category="0"><srvb:implementation adtcore:name="{n}"/></srvb:binding></srvb:serviceBinding>')


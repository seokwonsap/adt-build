# ---- type auto-detection from extension + first significant line ----
def detect(path, txt):
    head = '\n'.join(l for l in txt.splitlines()
                     if l.strip() and not l.lstrip().startswith(('*', '"', '@', '//', '<?xml')))[:400].upper()
    ext = os.path.splitext(path)[1].lower()
    if ext == '.asdcls': return 'dcl'
    if ext == '.assrvd': return 'srvd'
    if ext == '.asbdef' or 'IMPLEMENTATION IN CLASS' in head or 'DEFINE BEHAVIOR FOR' in head: return 'bdef'
    if ext == '.asddls' or 'DEFINE ' in head:
        if 'DEFINE STRUCTURE' in head: return 'stru'
        if 'DEFINE TABLE TYPE' in head: return None   # TTYP not supported yet (don't mis-detect as 'tabl')
        if 'DEFINE TABLE FUNCTION' in head: return 'cds'   # AMDP table function rides the DDLS endpoint
        if 'DEFINE TABLE' in head: return 'tabl'
        if 'DEFINE SERVICE' in head: return 'srvd'
        if 'DEFINE ROLE' in head: return 'dcl'
        if re.search(r'DEFINE\s+(ROOT\s+)?(VIEW|ABSTRACT|HIERARCHY)', head): return 'cds'
    if ext == '.xml' or txt.lstrip().startswith('<'):
        if '<XSL' in head or '<XSL:' in txt.upper(): return 'xslt'
        if 'DOMA:DOMAIN' in txt.upper(): return 'doma'
        if 'DTEL/DE' in txt.upper() or 'DTEL:DATAELEMENT' in txt.upper(): return 'dtel'
    # .abap by first keyword
    kw = head.split()[0] if head.split() else ''
    return {'CLASS':'class','INTERFACE':'intf','REPORT':'prog','PROGRAM':'prog',
            'FUNCTION':'fm','TYPE-POOL':'typegrp'}.get(kw)

# ---- http (urllib + cookie jar; no curl/deps) ----
_ctx = None   # TLS context — set in configure(): verify certs by default, --insecure to skip (self-signed dev)
def opener():
    return urllib.request.build_opener(urllib.request.HTTPCookieProcessor(http.cookiejar.CookieJar()),
                                       urllib.request.HTTPSHandler(context=_ctx))
def q(path, **p):
    p = {k: v for k, v in p.items() if v not in (None, '')}   # drop empty params (e.g. corrNr when no transport)
    if CLIENT: p['sap-client'] = CLIENT                       # unset -> omit; server uses the logon default client
    if not p: return path
    return path + ('&' if '?' in path else '?') + urllib.parse.urlencode(p)
def req(op, method, path, data=None, token=None, ct=None, accept=None, _try=2):
    h = {'Authorization': AUTH, 'X-sap-adt-sessiontype': 'stateful', 'Accept': accept or '*/*'}
    if token: h['X-CSRF-Token'] = token
    if ct: h['Content-Type'] = ct
    r = urllib.request.Request(B_URL + path, data=data, method=method, headers=h)
    try:
        rs = op.open(r, timeout=50); st, body, hd = rs.status, rs.read().decode('utf-8', 'replace'), rs.headers
    except urllib.error.HTTPError as e:
        st, body, hd = e.code, e.read().decode('utf-8', 'replace'), e.headers
    except Exception as e:
        st, body, hd = 0, str(e), {}
    if st in (503, 0) and _try > 1:   # transient (server busy / conn drop) → retry once
        return req(op, method, path, data, token, ct, accept, _try - 1)
    return st, body, hd
def csrf(op):
    _, _, hd = req(op, 'GET', q('/sap/bc/adt/discovery'), token='Fetch')
    return hd.get('x-csrf-token', '') if hd else ''

# ---- build engine ----
def _err(body):
    for a, b in re.findall(r'<message[^>]*>([^<]*)</message>|<txt>([^<]*)</txt>', body or ''):
        m = (a or b).strip()
        if m and 'cancelled' not in m.lower(): print('   !', m)
    if VERBOSE and body:   # non-XML (JSON/HTML) error bodies leave the regex empty -> dump raw to debug
        print('   . raw:', re.sub(r'\s+', ' ', body.strip())[:800])
def _attr(s, name):  # pull an XML attribute value regardless of attribute order
    m = re.search(name + r'="([^"]*)"', s or ''); return m.group(1) if m else ''
def _aunit(op, obj):  # run ABAP Unit on an object URI, print a pass/fail summary
    # ⚠ <options> & children are UNqualified (no aunit: prefix) and media is application/* —
    #   a namespaced <aunit:options> is silently ignored → empty <runResult/> (looks green, ran nothing).
    body = ('<?xml version="1.0" encoding="UTF-8"?>'
            '<aunit:runConfiguration xmlns:aunit="http://www.sap.com/adt/aunit">'
            '<external><coverage active="false"/></external>'
            '<options><uriType value="semantic"/>'
            '<testDeterminationStrategy sameProgram="true" assignedTests="false"/>'
            '<testRiskLevels harmless="true" dangerous="true" critical="true"/>'
            '<testDurations short="true" medium="true" long="true"/>'
            '<withNavigationUri enabled="true"/></options>'
            '<adtcore:objectSets xmlns:adtcore="http://www.sap.com/adt/core">'
            '<objectSet kind="inclusive"><adtcore:objectReferences>'
            f'<adtcore:objectReference adtcore:uri="{obj}"/>'
            '</adtcore:objectReferences></objectSet></adtcore:objectSets></aunit:runConfiguration>')
    st, b, _ = req(op, 'POST', q('/sap/bc/adt/abapunit/testruns'), data=body.encode(),
                   token=csrf(op), ct='application/*', accept='application/*')
    if st >= 400: print(f'  test: HTTP {st}'); _err(b); return False
    if '<program' not in (b or ''):   # no <program> = nothing ran (NOT a pass — see LEARNINGS I6)
        print('  test: no ABAP Unit tests found for this object'); return None
    methods = re.findall(r'<testMethod\b[^>]*adtcore:name="([^"]*)"', b)
    fails = []
    for at, inner in re.findall(r'<alert\b([^>]*)>(.*?)</alert>', b, re.S):
        sev, kind = _attr(at, 'severity'), _attr(at, 'kind')
        if sev in ('critical', 'fatal') or 'abort' in kind.lower():
            ti = re.search(r'<title>([^<]*)', inner)
            loc = re.search(r'start=(\d+)', inner)   # line number from the alert's stack/navigation URI
            fails.append((kind or sev, html.unescape(ti.group(1).strip()) if ti else '', loc.group(1) if loc else ''))
    if fails:
        print(f'  test: {len(methods)} methods, {len(fails)} FAILED')
        for kind, ti, line in fails[:20]: print(f'     x [{kind}] {ti}' + (f'  @{line}' if line else ''))
        return False
    print(f'  test: {len(methods)} methods, all passed')
    return True
def _atc(op, obj, max_prio=2):  # run ATC; gate on findings at priority 1..max_prio (P3 advisory). returns True/False/None
    _, cb, _ = req(op, 'GET', q('/sap/bc/adt/atc/customizing'), accept='application/*')
    m = (re.search(r'name="systemCheckVariant"[^>]*value="([^"]*)"', cb or '')
         or re.search(r'value="([^"]*)"[^>]*name="systemCheckVariant"', cb or ''))
    variant = m.group(1) if m else ''
    if not variant: print('  atc: could not resolve system check variant'); return None
    _, wl, _ = req(op, 'POST', q('/sap/bc/adt/atc/worklists', checkVariant=variant),
                   token=csrf(op), accept='text/plain')
    wl = (wl or '').strip()
    if not re.match(r'^[0-9A-Fa-f]{8,}$', wl): print(f'  atc: worklist failed ({wl[:60]})'); return None
    run = ('<?xml version="1.0" encoding="UTF-8"?>'
           '<atc:run maximumVerdicts="100" xmlns:atc="http://www.sap.com/adt/atc">'
           '<objectSets xmlns:adtcore="http://www.sap.com/adt/core">'
           '<objectSet kind="inclusive"><adtcore:objectReferences>'
           f'<adtcore:objectReference adtcore:uri="{obj}"/>'
           '</adtcore:objectReferences></objectSet></objectSets></atc:run>')
    st, rb, _ = req(op, 'POST', q('/sap/bc/adt/atc/runs', worklistId=wl), data=run.encode(),
                    token=csrf(op), ct='application/xml', accept='application/xml')
    if st >= 400: print(f'  atc: HTTP {st}'); _err(rb); return None   # couldn't run → advisory, don't gate the build
    sm = re.search(r'FINDING_STATS</[^>]*>\s*<[^>]*description>([^<]*)', rb or '')
    nums = [int(x) for x in re.findall(r'\d+', sm.group(1))] if sm else []
    total, gated = (sum(nums), sum(nums[:max_prio])) if nums else (None, None)
    if total == 0: print('  atc: clean (0 findings)'); return True
    _, wb, _ = req(op, 'GET', q(f'/sap/bc/adt/atc/worklists/{wl}', includeExemptedFindings='false'), accept='application/*')
    finds = re.findall(r'<[\w:]*finding\b([^>]*)', wb or '')
    print(f'  atc: {total if total is not None else len(finds)} findings'
          + (f' (prio {sm.group(1)})' if sm else '')
          + (f'  [gate P1-{max_prio}: {gated}]' if gated is not None else ''))
    shown, seen = 0, set()   # the worklist can list each finding more than once → dedup by (message, line)
    for at in finds:
        msg = html.unescape(_attr(at, 'messageTitle') or _attr(at, 'checkTitle'))
        if not msg: continue
        ln = re.search(r'start=(\d+)', _attr(at, 'location'))
        key = (msg, ln.group(1) if ln else '')
        if key in seen: continue
        seen.add(key)
        print(f'     - P{_attr(at, "priority")} {msg}' + (f'  @{ln.group(1)}' if ln else ''))
        shown += 1
        if shown >= 20: print('     … (more)'); break
    return (gated == 0) if gated is not None else (len(finds) == 0)
def _verdict(rc, show=True):  # one final gate line; returns rc so callers can `return _verdict(rc)`
    if show:
        print('  => ' + {0: 'PASS', 1: 'FAIL activate/compile', 2: 'FAIL unit', 3: 'FAIL atc'}.get(rc, 'FAIL') + f'  [exit {rc}]')
    return rc
def _doc(op, obj):  # report ABAP Doc ("!) coverage for a code object — verify-loop guardrail, READ-ONLY (no slop stubs)
    st, src, _ = req(op, 'GET', q(obj + '/source/main'), accept='text/plain')
    if st >= 400 or not src: print(f'  doc: source unavailable (HTTP {st})'); return
    lines = src.splitlines()
    def documented(i):   # is the declaration on line i preceded (past blank lines) by an ABAP Doc "! line?
        j = i - 1
        while j >= 0 and not lines[j].strip(): j -= 1
        return j >= 0 and lines[j].lstrip().startswith('"!')
    hdr, meths, impl = None, [], False
    for i, ln in enumerate(lines):
        if re.match(r'^\s*(?:CLASS|INTERFACE)\s+\S+\s+IMPLEMENTATION', ln, re.I): impl = True   # stop at impl part
        if hdr is None and re.match(r'^\s*(?:CLASS|INTERFACE|REPORT|PROGRAM|FUNCTION)\b', ln, re.I) \
           and not re.search(r'\bIMPLEMENTATION\b', ln, re.I): hdr = documented(i)
        if not impl:
            m = re.match(r'^\s*(?:CLASS-)?METHODS:?\s+([\w~]+)', ln, re.I)
            if m: meths.append((m.group(1), documented(i)))
    nd = sum(1 for _, d in meths if d)
    parts = (['header ' + ('ok' if hdr else 'MISSING')] if hdr is not None else []) \
          + ([f'methods {nd}/{len(meths)} documented'] if meths else [])
    print('  doc: ' + (', '.join(parts) if parts else 'no public API to document'))
    missing = [n for n, d in meths if not d]
    if missing: print('     undocumented: ' + ', '.join(missing[:15]) + (' …' if len(missing) > 15 else ''))
def build(t, name, src=None, group=None, srvd=None, run=False, test=False, atc=False, doc=False, atc_max_prio=2):
    s = TYPES[t]; nl = name.lower(); mode = s.get('mode', 'src')
    coll = s['coll'] or f"/sap/bc/adt/functions/groups/{(group or '').lower()}/fmodules"
    obj = f"{coll}/{nl}"
    A, B = opener(), opener()
    if src is None and mode != 'createonly':   # verify-only: object already exists, nothing to upload
        print(f"[verify] {name}"); rc = 0
        if run and s.get('run'):
            _, rb, _ = req(B, 'POST', q(f'/sap/bc/adt/oo/classrun/{nl}'), token=csrf(B), accept='text/plain')
            print('--- RUN ---'); print(rb)
        if test and _aunit(B, obj) is False: rc = 2
        if atc and _atc(B, obj, atc_max_prio) is False and rc == 0: rc = 3
        if doc and t in ('class', 'intf', 'prog', 'fm'): _doc(B, obj)
        return _verdict(rc)
    cre = s['cre'](name, group=group, srvd=srvd); rc = 0
    st, cb, _ = req(A, 'POST', q(coll, corrNr=TR), data=cre.encode(), token=csrf(A), ct=s['media'])
    out = [f"create {st}"]
    if st >= 400 and 'already exist' not in cb.lower(): _err(cb); rc = 1   # "already exists" on rebuild is benign
    if mode != 'createonly':
        lst, lb, _ = req(A, 'POST', q(obj, _action='LOCK', accessMode='MODIFY'), token=csrf(A),
                         accept='application/vnd.sap.as+xml;dataname=com.sap.adt.lock.Result')
        m = re.search(r'<LOCK_HANDLE>([^<]*)', lb); lh = m.group(1).strip() if m else ''
        if not lh:   # lock failed -> surface it and stop, don't PUT with an empty lock handle
            out.append(f'lock FAILED (http={lst})'); print('  '.join(out)); _err(lb); return _verdict(1)
        if mode == 'xml': purl, pct = q(obj, lockHandle=lh, corrNr=TR), s['media']
        else:             purl, pct = q(obj + '/source/main', lockHandle=lh, corrNr=TR), 'text/plain; charset=utf-8'
        st, pb, _ = req(A, 'PUT', purl, data=open(src, 'rb').read().replace(b'\r\n', b'\n'), token=csrf(A), ct=pct)
        out.append(f"put {st}")
        if st >= 400: _err(pb); rc = 1
        req(A, 'POST', q(obj, _action='UNLOCK', lockHandle=lh), token=csrf(A))
    act = (f'<?xml version="1.0" encoding="UTF-8"?><adtcore:objectReferences {NS}>'
           f'<adtcore:objectReference adtcore:uri="{obj}" adtcore:type="{s["atype"]}" adtcore:name="{name}"/></adtcore:objectReferences>')
    _, ab, _ = req(B, 'POST', q('/sap/bc/adt/activation', method='activate', preauditRequested='false'),
                   data=act.encode(), token=csrf(B), ct='application/xml')
    m = re.search(r'activationExecuted="([^"]*)"', ab)
    out.append(f'activate={m.group(1) if m else "?"}')
    print('  '.join(out)); _err(ab)
    if re.search(r'\btype="[EA]"', ab or ''): rc = 1   # E=error / A=abort in activation = compile/type failure ("false" with no E/A = benign no-op = ok)
    if s.get('publish'):
        pub = (f'<?xml version="1.0" encoding="UTF-8"?><adtcore:objectReferences {NS}>'
               f'<adtcore:objectReference adtcore:uri="{obj}" adtcore:type="SRVB/SVB" adtcore:name="{name}"/></adtcore:objectReferences>')
        st, pb, _ = req(B, 'POST', q('/sap/bc/adt/businessservices/odatav4/publishjobs', servicename=name, serviceversion='0001'),
                        data=pub.encode(), token=csrf(B), ct='application/xml')
        sm = re.search(r'<SHORT_TEXT>([^<]*)', pb)
        if sm: print('  publish:', sm.group(1))
        else:  print(f'  publish {st}:'); _err(pb)
    if run and s.get('run'):
        _, rb, _ = req(B, 'POST', q(f'/sap/bc/adt/oo/classrun/{nl}'), token=csrf(B), accept='text/plain')
        print('--- RUN ---'); print(rb)
    if rc == 0:   # verify only a cleanly-activated object (broken source can't be meaningfully tested)
        if test and _aunit(B, obj) is False: rc = 2
        if atc and _atc(B, obj, atc_max_prio) is False and rc == 0: rc = 3
        if doc and t in ('class', 'intf', 'prog', 'fm'): _doc(B, obj)
    return _verdict(rc, show=bool(rc or test or atc))

# ---- probe: discover, don't assume ----
def probe(pkg=None):
    op = opener()
    def g1(body, rx, d='?'):
        m = re.search(rx, body); return m.group(1) if m else d
    print(f"host     : {B_URL}")
    print(f"user     : {USER}")
    print(f"client   : {CLIENT or '(omitted -> server logon default)'}")
    st, *_ = req(op, 'GET', q('/sap/bc/adt/discovery'))
    print(f"connect  : discovery http={st}  ({'ok' if st and st < 300 else 'AUTH or URL problem'})")
    pkg = pkg or PKG
    if not pkg:
        print("package  : (none set - SAP_PACKAGE / --package)")
    else:
        st, pb, _ = req(op, 'GET', q('/sap/bc/adt/packages/' + pkg.lower()))
        if st == 404:
            print(f"package  : {pkg}  NOT FOUND")
        elif st and st < 300:
            typ = g1(pb, r'adtcore:type="([^"]*)"')
            resp = g1(pb, r'adtcore:responsible="([^"]*)"')
            swc = g1(pb, r'pak:softwareComponent pak:name="([^"]*)"', '')
            kind = 'TRANSPORTABLE: a transport request is required' if typ == 'DEVC/K' else 'local: no transport needed'
            print(f"package  : {pkg}  exists (type={typ}, responsible={resp}, softwareComponent={swc})")
            print(f"           -> {kind}")
        else:
            print(f"package  : {pkg}  http={st}")
    if not TR:
        print("transport: (none set - required only for transportable packages)")
    else:
        st, tb, _ = req(op, 'GET', q('/sap/bc/adt/cts/transportrequests/' + TR))
        if st and st < 300:
            status, owner = g1(tb, r'tm:status_text="([^"]*)"'), g1(tb, r'tm:owner="([^"]*)"')
            warn = '' if (status == 'Modifiable' and owner == USER) else '   <-- not modifiable or not owned by you'
            print(f'transport: {TR}  [{status}] owner={owner}{warn}')
        else:
            print(f"transport: {TR}  http={st} (not found?)")

# ---- cli ----
def main():
    ap = argparse.ArgumentParser(description='Build any ABAP object headless (auto type+name).')
    ap.add_argument('file', nargs='?', help='source file (type+name auto-detected)')
    ap.add_argument('--type'); ap.add_argument('--name'); ap.add_argument('--src')
    ap.add_argument('--group', help='function module: parent group')
    ap.add_argument('--srvd',  help='service binding: service definition')
    ap.add_argument('--run', action='store_true', help='class: run classrun after activate')
    ap.add_argument('--test', action='store_true', help='run ABAP Unit after activate (verify loop)')
    ap.add_argument('--atc', action='store_true', help='run ATC static checks after activate (verify loop)')
    ap.add_argument('--doc', action='store_true', help='report ABAP Doc coverage of the public API (verify loop)')
    ap.add_argument('--atc-max-prio', type=int, default=2, help='ATC gate: fail on findings at priority 1..N (default 2; P3 = advisory)')
    ap.add_argument('--host', help='SAP base URL (overrides SAP_URL)'); ap.add_argument('--user')
    ap.add_argument('--client'); ap.add_argument('--package'); ap.add_argument('--transport')
    ap.add_argument('--insecure', action='store_true', help='skip TLS cert verification (self-signed dev systems only)')
    ap.add_argument('--verbose', action='store_true', help='dump the raw server response body on errors (debug non-XML errors)')
    a = ap.parse_args()
    configure(a)
    if a.file == 'probe':
        probe(a.package); return
    t, name, src = a.type, a.name, a.src or a.file
    if a.file and not t:
        txt = open(a.file, encoding='utf-8', errors='replace').read()
        t = detect(a.file, txt)
        if not t: sys.exit(f"could not detect type from {a.file} - pass --type")
        if not name:
            nr = TYPES[t].get('name_re')
            if nr:
                m = re.search(nr, txt, re.I)
                name = m.group(1).upper() if m else None
            if not name:  # fallback: filename stem
                name = os.path.splitext(os.path.basename(a.file))[0].upper()
    if not t or t not in TYPES: sys.exit(f"unknown/!type: {t} (one of: {', '.join(TYPES)})")
    if not name: sys.exit("need --name")
    if t == 'fm' and not a.group: sys.exit("fm needs --group <GROUP>")
    if t == 'srvb' and not a.srvd: sys.exit("srvb needs --srvd <SERVICE_DEFINITION>")
    print(f"[{t}] {name}" + (f" in {a.group}" if a.group else "") + (f" -> {a.srvd}" if a.srvd else ""))
    sys.exit(build(t, name, src=src, group=a.group, srvd=a.srvd, run=a.run, test=a.test, atc=a.atc, doc=a.doc, atc_max_prio=a.atc_max_prio) or 0)

if __name__ == '__main__':
    main()
